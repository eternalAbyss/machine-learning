# ── Apple Health Explorer — Environment Config ────────────────────────────────

# Path to your unzipped Apple Health export.xml
HEALTH_EXPORT_XML=~/Downloads/apple_health_export/export.xml

# Directory where cleaned parquet files will be saved
# Defaults to the same folder as export.xml if not set
HEALTH_OUTPUT_DIR=~/Downloads/apple_health_export

# Your local timezone (used for converting all timestamps)
# Find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for AI insights (no need to change this usually)
ANTHROPIC_MODEL=claude-sonnet-4-20250514